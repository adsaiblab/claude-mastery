# ─── Mode ──────────────────────────────────────────────────────────────
# 'local' en dev → adapter DB = src/data/progress.json, auth stubée (dev@local)
# 'production' en prod → adapter DB = Supabase, auth réelle
PUBLIC_ENV=local

# URL canonique de l'app (dev vs prod)
PUBLIC_SITE_URL=http://localhost:4321

# Version affichée dans le footer
PUBLIC_APP_VERSION=0.1.0

# ─── Supabase (prod uniquement — ignoré si PUBLIC_ENV=local) ───────────
# URL de l'instance Supabase self-hosted ou cloud
PUBLIC_SUPABASE_URL=

# Clé publique — safe côté client
PUBLIC_SUPABASE_ANON_KEY=

# Clé service — JAMAIS côté client. Utilisée par les pages SSR pour bypass RLS quand nécessaire.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Expert gate ────────────────────────────────────────────────────────
# Liste séparée par virgules des emails autorisés à accéder à /05-expert et /architecture-patterns.
# En local (PUBLIC_ENV=local), dev@local est Expert automatiquement.
EXPERT_USER_EMAILS=toi@ton-domaine.com
